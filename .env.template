# Content Harness Engine configuration
# Copy this file to `.env` and fill in the real values.

# Optional OpenClaw runtime override for host-native capabilities.
# Format: module:ClassOrFactory
# The runtime should expose call_llm/search/read_text/generate_image/publish_wechat_draft when available
OPENCLAW_RUNTIME=your_openclaw_runtime_module:YourRuntimeClassOrFactory

# OpenAI API key is optional fallback for text generation and title/script generation
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API key for image generation
GEMINI_API_KEY=your_gemini_api_key_here

# Optional image model priority list, comma-separated.
# Default: imagen-4.0-fast-generate-001,imagen-4.0-generate-001,imagen-4.0-ultra-generate-001
GEMINI_IMAGE_MODEL_PRIORITY=imagen-4.0-fast-generate-001,imagen-4.0-generate-001,imagen-4.0-ultra-generate-001

# Optional Gemini vision model for image review / quality gating
GEMINI_VISION_MODEL=gemini-2.5-flash

# Optional Gemini model for text generation
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Tavily API key for research/search
TAVILY_API_KEY=your_tavily_api_key_here

# WeChat official account credentials for draft posting
WECHAT_APP_ID=your_wechat_app_id_here
WECHAT_APP_SECRET=your_wechat_app_secret_here

# Output directory for generated Obsidian assets
OUTPUT_DIR=/path/to/agent-workspace/content-harness-output

# Optional OpenClaw host
OPENCLAW_HOST=http://localhost:8000
