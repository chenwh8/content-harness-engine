# Content Harness Engine Configuration

# Gemini API Key for Visualist Agent (imagen-4.0-generate-001 for image generation)
# Also supports nano-banana-pro-preview model if available on your key
GEMINI_API_KEY=your_gemini_api_key_here

# Tavily API Key for Researcher Agent
TAVILY_API_KEY=your_tavily_api_key_here

# Output directory for Obsidian assets
OUTPUT_DIR=/path/to/your/obsidian/vault/content-harness-output

# OpenClaw specific configurations (if any)
OPENCLAW_HOST=http://localhost:8000
